# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-only)
ANTHROPIC_API_KEY=

# Lemlist (server-only — prospecting + enrichment)
LEMLIST_API_KEY=

# Dev sign-in stub (preview branches only — NEVER set on production)
# When NEXT_PUBLIC_AUTH_MODE=dev, /auth/login renders a one-click button that
# signs in as DEV_USER_EMAIL via admin.generateLink + verifyOtp on the server.
NEXT_PUBLIC_AUTH_MODE=
DEV_USER_EMAIL=

# Per-org Anthropic budget ceiling (USD per calendar month).
# Phase A safety layer enforces a flat ceiling; Phase H replaces with per-tier.
DEFAULT_AI_BUDGET_USD=5
